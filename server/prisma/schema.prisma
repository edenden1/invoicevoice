generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  invoices      Invoice[]
  customers     Customer[]
  laborRates    LaborRate[]
  materials     Material[]
}

model Profile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName    String
  ownerName       String
  phone           String
  tradeType       TradeType
  licenseNumber   String?
  logoUrl         String?

  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  zip             String?

  // Stripe Connect (receiving payments from customers)
  stripeAccountId String?
  stripeOnboarded Boolean @default(false)

  // Stripe Billing (InvoiceVoice subscription)
  stripeCustomerId     String?
  subscriptionId       String?
  subscriptionStatus   String   @default("trialing") // trialing | active | past_due | canceled | unpaid
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?

  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Invoice {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  invoiceNumber   String
  status          InvoiceStatus @default(DRAFT)

  customerName    String
  customerPhone   String?
  customerEmail   String?
  serviceAddress  String?
  description     String?

  lineItems       LineItem[]
  subtotal        Float
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float

  pdfUrl          String?
  stripePaymentId String?
  stripePaymentUrl String?

  sentAt          DateTime?
  paidAt          DateTime?
  paymentMethod   String?   // 'stripe' | 'cash' | 'check' | 'venmo' | 'zelle' | 'paypal' | 'bank_transfer' | 'other'
  voiceTranscript String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([customerId])
  @@index([status])
}

model LineItem {
  id          String       @id @default(uuid())
  invoiceId   String
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  type        LineItemType
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  createdAt   DateTime     @default(now())
}

model LaborRate {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  ratePerHour Float
  isDefault   Boolean @default(false)

  @@index([userId])
}

model Material {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  category    String
  defaultPrice Float
  unit        String  @default("each")

  @@index([userId])
}

enum TradeType {
  PLUMBING
  ELECTRICAL
  HVAC
  GENERAL_HANDYMAN
  LOCKSMITH
  PAINTING
  LANDSCAPING
  CLEANING
  APPLIANCE_REPAIR
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum LineItemType {
  LABOR
  MATERIAL
  FLAT_RATE
  OTHER
}
