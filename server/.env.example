# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/invoicevoice"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# ─── Whisper (speech-to-text) ─────────────────────────────────────────────────
# 'groq' (default, free tier) | 'openai'
WHISPER_PROVIDER="groq"

# ─── Groq (free Whisper — get key at console.groq.com) ──────────────────────
GROQ_API_KEY="gsk_..."

# ─── OpenAI (optional — only needed if WHISPER_PROVIDER=openai or LLM_PROVIDER=openai)
OPENAI_API_KEY="sk-..."

# ─── PayMe (payme.io) ────────────────────────────────────────────────────────
PAYME_API_KEY="your-payme-api-key"
PAYME_SELLER_KEY="your-payme-seller-key"
PAYME_WEBHOOK_SECRET="your-payme-webhook-secret"
# Create a subscription plan in PayMe dashboard for $29/month recurring
PAYME_SUBSCRIPTION_PLAN_ID="your-plan-id"
PAYME_TRIAL_DAYS=14
# 'sandbox' or 'live'
PAYME_ENVIRONMENT="sandbox"

# ─── Twilio (optional — SMS delivery) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
CLIENT_URL="http://localhost:8081"
APP_SCHEME="invoicevoice"   # Must match the "scheme" in mobile/app.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to simulate all payment services (no real PayMe calls).
# All PayMe env vars above can be omitted when demo mode is enabled.
DEMO_MODE="false"

# ─── File Upload ─────────────────────────────────────────────────────────────
# UPLOAD_TEMP_DIR="/tmp/invoicevoice"   # Optional, defaults to ./tmp
