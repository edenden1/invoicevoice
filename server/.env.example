# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/invoicevoice"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create in Stripe Dashboard → Products → Add Product → $29/month recurring price
STRIPE_PRICE_ID="price_..."
STRIPE_TRIAL_DAYS=14

# ─── Twilio (optional — SMS delivery) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
CLIENT_URL="http://localhost:8081"
APP_SCHEME="invoicevoice"   # Must match the "scheme" in mobile/app.json

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── File Upload ─────────────────────────────────────────────────────────────
# UPLOAD_TEMP_DIR="/tmp/invoicevoice"   # Optional, defaults to ./tmp
